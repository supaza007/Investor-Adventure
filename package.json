{
  "name": "invest-deckbuilder",
  "private": true,
  "version": "0.1.0",
  "description": "เกมการ์ดผจญภัย สอนความรู้การลงทุน",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Investor Adventure",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_IS_DEV=true electron .\"",
    "electron:build": "vite build && electron-builder",
    "build:web": "vite build --mode web",
    "test": "node --test \"src/game/engine/*.test.js\"",
    "sim": "node scripts/sim.mjs",
    "optimize-images": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.3.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.investoradventure.app",
    "productName": "Investor Adventure",
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    }
  }
}
